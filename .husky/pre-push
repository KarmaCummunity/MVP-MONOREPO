#!/usr/bin/env sh
. "$(dirname -- "$0")/_/husky.sh"

# Pre-push hook - Run quality checks before pushing
echo "🚀 Running pre-push quality gate..."

# Get the remote and URL being pushed to
REMOTE="$1"
URL="$2"

# Determine which workspace changed
CURRENT_BRANCH=$(git rev-parse --abbrev-ref HEAD)
echo "Current branch: $CURRENT_BRANCH"

# Check if API files changed
API_CHANGED=$(git diff --name-only origin/main...HEAD 2>/dev/null | grep "^apps/api/" || echo "")

if [ -n "$API_CHANGED" ]; then
  echo ""
  echo "📦 API changes detected - running quality gate..."
  echo ""
  
  cd apps/api || exit 1
  
  # Run the quality gate check script
  if ./scripts/check-quality-gate.sh main; then
    echo ""
    echo "✅ API Quality Gate passed"
  else
    echo ""
    echo "❌ API Quality Gate failed - push blocked"
    echo ""
    echo "Your code contains issues that would fail CI/CD checks."
    echo "Please fix the issues above before pushing."
    echo ""
    echo "To skip this check (not recommended): git push --no-verify"
    exit 1
  fi
  
  cd ../.. || exit 1
else
  echo "ℹ️  No API changes detected - skipping quality gate"
fi

# Check if mobile files changed (for future)
MOBILE_CHANGED=$(git diff --name-only origin/main...HEAD 2>/dev/null | grep "^apps/mobile/" || echo "")
if [ -n "$MOBILE_CHANGED" ]; then
  echo "ℹ️  Mobile changes detected - quality checks not implemented yet"
fi

echo ""
echo "✅ Pre-push checks completed - safe to push"
