# ========================================
# @kc/dev-bot – Environment Configuration
# ========================================
# Copy to .env and fill values. Never commit .env.
# Telegram dev agent – requires Telegram Bot Token and Gemini API key.

# Required
TELEGRAM_TOKEN=your-telegram-bot-token-from-BotFather
GEMINI_API_KEY=your-google-gemini-api-key

# Optional – base path for monorepo (default: parent of dev-bot)
# BASE_DIR=../
