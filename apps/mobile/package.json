    "e2e:local": "bash scripts/run-local-e2e.sh",
    "e2e:maestro": "bash scripts/run-maestro-smoke.sh",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "prebuild:web": "bash scripts/update-build-version.sh",
    "build:web": "EXPO_PUBLIC_API_BASE_URL=https://kc-mvp-server-production.up.railway.app expo export --platform web",
    "postbuild:web": "bash scripts/restore-build-placeholders.sh",
    "build:web:local": "EXPO_PUBLIC_API_BASE_URL=http://localhost:3001 expo export:web",
    "audit:colors": "TS_NODE_COMPILER_OPTIONS='{\"module\":\"CommonJS\",\"moduleResolution\":\"node\"}' ts-node scripts/audit-colors.ts",
    "audit:texts": "TS_NODE_COMPILER_OPTIONS='{\"module\":\"CommonJS\",\"moduleResolution\":\"node\"}' ts-node scripts/audit-texts.ts",
    "audit:nav-routes": "TS_NODE_COMPILER_OPTIONS='{\"module\":\"CommonJS\",\"moduleResolution\":\"node\"}' ts-node scripts/audit-navigate-duplicate-routes.ts",
    "audit:constants": "ts-node scripts/audit-constants.ts",
    "audit:responsive": "ts-node scripts/audit-responsive.ts",
    "audit:unused": "ts-node scripts/find-unused-files.ts",
    "audit:all": "TS_NODE_COMPILER_OPTIONS='{\"module\":\"CommonJS\",\"moduleResolution\":\"node\"}' node ./node_modules/ts-node/dist/bin.js scripts/audit-all.ts",
    "test": "jest --forceExit",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage --forceExit",
    "test:ci": "jest --ci --coverage --maxWorkers=2 --forceExit",
    "_TODO_ADD_SCRIPTS": "// TODO: Add missing scripts: lint, type-check, format, security-audit, bundle-analyze",
    "lint": "ESLINT_USE_FLAT_CONFIG=false eslint . --ext .ts,.tsx --max-warnings 1000"
