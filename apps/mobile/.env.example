# ========================================
# @kc/mobile – Environment Configuration
# ========================================
# Copy to .env and fill values. Never commit .env.
# Local: apps/mobile/.env | EAS Build: set as Secrets in EAS Dashboard

# Environment
EXPO_PUBLIC_ENVIRONMENT=development

# API – local dev: http://localhost:3001 | E2E: set by run-local-e2e.sh
EXPO_PUBLIC_API_BASE_URL=http://localhost:3001

# Firebase (from Firebase Console → Project settings)
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=
EXPO_PUBLIC_FIREBASE_MEASUREMENT_ID=

# Google OAuth (from Google Cloud Console → APIs & Services → Credentials)
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=

# Feature Flags
EXPO_PUBLIC_USE_BACKEND=1
EXPO_PUBLIC_USE_FIRESTORE=0

# Admin (comma-separated emails for admin access)
EXPO_PUBLIC_ADMIN_EMAILS=
