mn":44,"suggestions":[{"messageId":"replaceEmptyInterfaceWithSuper","fix":{"range":[7490,7670],"text":"type DonationCategoriesResponse = BaseApiResponse<Array<{\n  id: string;\n  name: string;\n  nameHe: string;\n  icon: string;\n  count: number;\n  description?: string;\n}>>"},"desc":"Replace empty interface with a type alias."}],"suppressions":[{"kind":"directive","justification":""}]},{"ruleId":"@typescript-eslint/no-empty-object-type","severity":1,"message":"An interface declaring no members is equivalent to its supertype.","line":694,"column":18,"nodeType":"Identifier","messageId":"noEmptyInterfaceWithSuper","endLine":694,"endColumn":36,"suggestions":[{"messageId":"replaceEmptyInterfaceWithSuper","fix":{"range":[14951,15391],"text":"type FileUploadResponse = BaseApiResponse<{\n  /** Unique file identifier */\n  fileId: string;\n  /** Direct URL to uploaded file */\n  url: string;\n  /** CDN URL for optimized delivery */\n  cdnUrl?: string;\n  /** Thumbnail URL (for images) */\n  thumbnailUrl?: string;\n  /** Upload metadata */\n  metadata: {\n    originalName: string;\n    size: number;\n    mimeType: string;\n    uploadedAt: string;\n    expiresAt?: string;\n  };\n}>"},"desc":"Replace empty interface with a type alias."}],"suppressions":[{"kind":"directive","justification":""}]},{"ruleId":"@typescript-eslint/no-empty-object-type","severity":1,"message":"An interface declaring no members is equivalent to its supertype.","line":839,"column":18,"nodeType":"Identifier","messageId":"noEmptyInterfaceWithSuper","endLine":839,"endColumn":37,"suggestions":[{"messageId":"replaceEmptyInterfaceWithSuper","fix":{"range":[18095,18801],"text":"type HealthCheckResponse = BaseApiResponse<{\n  /** Overall service status */\n  status: 'healthy' | 'degraded' | 'unhealthy';\n  \n  /** Individual service components */\n  services: {\n    database: 'healthy' | 'unhealthy';\n    redis: 'healthy' | 'unhealthy';\n    googleOAuth: 'healthy' | 'unhealthy';\n    storage: 'healthy' | 'unhealthy';\n  };\n  \n  /** Performance metrics */\n  metrics: {\n    responseTime: number;\n    memoryUsage: number;\n    cpuUsage: number;\n    activeConnections: number;\n  };\n  \n  /** Version information */\n  version: {\n    api: string;\n    database: string;\n    node: string;\n  };\n  \n  /** Uptime information */\n  uptime: {\n    seconds: number;\n    human: string;\n  };\n}>"},"desc":"Replace empty interface with a type alias."}],"suppressions":[{"kind":"directive","justification":""}]},{"ruleId":"@typescript-eslint/no-empty-object-type","severity":1,"message":"An interface declaring no members is equivalent to its supertype.","line":904,"column":18,"nodeType":"Identifier","messageId":"noEmptyInterfaceWithSuper","endLine":904,"endColumn":39,"suggestions":[{"messageId":"replaceEmptyInterfaceWithSuper","fix":{"range":[19418,19806],"text":"type BulkOperationResponse<T = unknown> = BaseApiResponse<{\n  /** Number of items processed successfully */\n  successCount: number;\n  /** Number of items that failed */\n  errorCount: number;\n  /** Total items attempted */\n  totalCount: number;\n  /** Results for each item */\n  results: Array<{\n    id: string;\n    success: boolean;\n    data?: T;\n    error?: string;\n  }>;\n}>"},"desc":"Replace empty interface with a type alias."}],"suppressions":[{"kind":"directive","justification":""}]}],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"/Users/navesarussi/KC/kc-monorepo/apps/mobile/google_auth/types/AuthTypes.ts","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"/Users/navesarussi/KC/kc-monorepo/apps/mobile/google_auth/utils/ErrorHandler.ts","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"fi