# Snyk (https://snyk.io) policy file, patches or ignores known vulnerabilities.
version: v1.25.1
# ignores vulnerabilities until expiry date; change duration by modifying expiry date
ignore:
  SNYK-JS-INFLIGHT-6095116:
    - '*':
        reason: None Given
        expires: 2026-03-26T21:02:16.942Z
        created: 2026-02-24T21:02:16.945Z
  SNYK-JS-MINIMATCH-15309438:
    - '*':
        reason: None Given
        expires: 2026-03-26T21:02:20.633Z
        created: 2026-02-24T21:02:20.638Z
  javascript/HardcodedNonCryptoSecret:
    - google_auth/GoogleAuthService.ts:
        reason: >
          STORAGE_KEYS values are AsyncStorage key names (identifiers), not
          secrets. Actual auth tokens are stored as values at those keys, never
          hardcoded.
        expires: 2027-06-01T00:00:00.000Z
        created: 2026-02-25T00:00:00.000Z
    - utils/authTestUtils.ts:
        reason: >
          Mock JWT token built at runtime (btoa) for unit-test assertions only.
          Not a real credential – signature is intentionally invalid.
        expires: 2027-06-01T00:00:00.000Z
        created: 2026-02-25T00:00:00.000Z
  javascript/OR:
    - bottomBarScreens/ProfileScreen.tsx:
        reason: >
          avatarSource is sanitised by sanitiseAvatarUrl() which rejects any URL
          that is not a valid http/https URI. React Native Image does not
          perform navigation/redirect; it is not an open-redirect sink.
        expires: 2027-06-01T00:00:00.000Z
        created: 2026-02-25T00:00:00.000Z
