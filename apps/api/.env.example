# ========================================
# @kc/api – Environment Configuration
# ========================================
# Copy to .env and fill in values. Never commit .env.
# Structure: apps/api/src/modules/{auth,users,donations,rides,posts,items,stats,admin,challenges,chat,notifications,sync}

# ========================================
# Server Configuration
# ========================================
# Port the server will listen on (default: 3001)
PORT=3001

# Environment: development, production, or test
# Use 'development' for dev environment, 'production' for prod
ENVIRONMENT=production

# Node environment: development, production, or test
NODE_ENV=production

# CORS origin - comma-separated list of allowed origins, or '*' for all
# Example: https://yourdomain.com,https://www.yourdomain.com
# Development: include localhost origins
# Production: only production domains
CORS_ORIGIN=*

# ========================================
# JWT Authentication (REQUIRED)
# ========================================
# JWT secret key for signing tokens - MUST be at least 32 characters
# Generate a secure random string: openssl rand -base64 32
# This is CRITICAL for JWT authentication to work
JWT_SECRET=your-super-secret-jwt-key-minimum-32-characters-required-here

# ========================================
# Database Configuration
# ========================================
# Option 1: Use DATABASE_URL (recommended for Railway/Heroku)
# For local development with Docker: use port 5435 (see docker-compose.yml)
# Example: postgresql://kc:YOUR_SECURE_PASSWORD@localhost:5435/kc_db
DATABASE_URL=postgresql://kc:YOUR_SECURE_PASSWORD@localhost:5435/kc_db

# Option 2: Use individual PostgreSQL variables (for local development)
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5435
# POSTGRES_USER=kc
# POSTGRES_PASSWORD=YOUR_SECURE_PASSWORD
# POSTGRES_DB=kc_db

# For local E2E (run-local-e2e.sh): if unset, uses change_me_in_env (docker-compose default)
# Set POSTGRES_PASSWORD here to match docker-compose, or leave empty for local E2E fallback

# SSL Configuration (optional, set to 'true' or 'require' for production)
# PG_SSL=require
# POSTGRES_SSL=require
# PGSSLMODE=require

# ========================================
# Redis Configuration
# ========================================
# Option 1: Use REDIS_URL (recommended for Railway/Upstash)
REDIS_URL=redis://localhost:6379

# Option 2: Use individual Redis variables
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_USERNAME=
# REDIS_PASSWORD=

# Redis TLS/SSL (set to 'true' if using rediss:// or TLS-enabled Redis)
# REDIS_TLS=false
# REDIS_SSL=false

# ========================================
# Google OAuth Configuration
# ========================================
# Google OAuth Client ID for authentication
GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com

# Google OAuth Client ID (public, can be exposed to frontend)
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com

# Google Places API Key (for location/places features)
GOOGLE_API_KEY=your-google-places-api-key

# ========================================
# Database Schema Management (Optional)
# ========================================
# Force full schema rebuild on startup (use with caution)
# FORCE_FULL_SCHEMA=false

# Skip full schema initialization (for production)
# SKIP_FULL_SCHEMA=0

# ========================================
# System Administration (REQUIRED)
# ========================================
# Root administrator email - the only email that should be hardcoded
# This user will be auto-promoted to super_admin on first login
# All other admins should be promoted via the admin panel
ROOT_ADMIN_EMAIL=your-admin-email@gmail.com

# ========================================
# Notes
# ========================================
# - JWT_SECRET is REQUIRED and must be at least 32 characters
# - DATABASE_URL or POSTGRES_* variables are REQUIRED
# - REDIS_URL or REDIS_* variables are REQUIRED
# - ROOT_ADMIN_EMAIL is REQUIRED for initial system setup
# - Generate secure secrets using: openssl rand -base64 32
# - Never commit .env file to version control
# - Use Railway/Heroku environment variables for production deployments
