# Snyk (https://snyk.io) policy file, patches or ignores known vulnerabilities.
version: v1.25.1
# ignores vulnerabilities until expiry date; change duration by modifying expiry date
ignore:
  javascript/HttpToHttps:
    - minimal-server.js:
        reason: >
          Health-check server sits behind a TLS-terminating load-balancer.
          External traffic is always HTTPS; this HTTP listener is internal only.
        expires: 2027-06-01T00:00:00.000Z
        created: 2026-02-25T00:00:00.000Z
    - src/minimal-server.ts:
        reason: >
          Health-check server sits behind a TLS-terminating load-balancer.
          External traffic is always HTTPS; this HTTP listener is internal only.
        expires: 2027-06-01T00:00:00.000Z
        created: 2026-02-25T00:00:00.000Z
  javascript/Sqli:
    - src/modules/items/items.service.ts:
    - src/items/items.service.ts:
        reason: >
          Table names come from tableFor() which validates against a hard-coded
          Set of allowed collection names. All queries then use pg-format %I for
          identifier quoting. No unsanitised user input reaches the query.
        expires: 2027-06-01T00:00:00.000Z
        created: 2026-02-25T00:00:00.000Z
    - src/services/admin-tables.service.ts:
        reason: >
          Pagination params are parsed as integers in the controller before
          being passed to the service. Fixed-param queries ($1, $2, $3) are
          used; no string interpolation of user values into SQL.
        expires: 2027-06-01T00:00:00.000Z
        created: 2026-02-25T00:00:00.000Z
    - src/modules/challenges/controllers/community-group-challenges.controller.ts:
    - src/controllers/community-group-challenges.controller.ts:
        reason: >
          sort_by is validated against an explicit allowlist of column names;
          sort_order is forced to 'ASC' or 'DESC'. The resulting identifiers are
          quoted via pg-format %I before being appended to the query.
        expires: 2027-06-01T00:00:00.000Z
        created: 2026-02-25T00:00:00.000Z
    - src/modules/admin/controllers/tasks.controller.ts:
    - src/controllers/tasks.controller.ts:
        reason: >
          The WHERE clause is built from fixed column names (status, priority,
          category) whose values are fully parameterised ($1, $2, …). No user
          input is used as a column name or identifier.
        expires: 2027-06-01T00:00:00.000Z
        created: 2026-02-25T00:00:00.000Z
    - src/modules/items/controllers/items-delivery.controller.ts:
    - src/modules/items/services/items-delivery.service.ts:
        reason: >
          All filter values (category, search, etc.) are passed as query params
          ($1, $2, ...). sort_by/sort_order validated against allowlist.
        expires: 2027-06-01T00:00:00.000Z
        created: 2026-02-26T00:00:00.000Z
    - src/scripts/run-sql.ts:
        reason: >
          sqlPath is validated: confined to projectRoot, .sql extension
          enforced, null-byte check applied. The file content is then passed to
          pool.query as a trusted migration script, not user-supplied data.
        expires: 2027-06-01T00:00:00.000Z
        created: 2026-02-25T00:00:00.000Z
    - src/scripts/verify-import.ts:
        reason: >
          Table names come from information_schema (system catalog); validated
          against a safe-name pattern and quoted with pg-format %I before use.
        expires: 2027-06-01T00:00:00.000Z
        created: 2026-02-25T00:00:00.000Z
