# ========================================
# @kc/api – Test Environment
# ========================================
# Copy to .env.test for local tests. Never commit .env.test.

# ========================================
# Test Database Configuration
# ========================================
# Use a separate database for tests to avoid corrupting dev/prod data
# Example: postgresql://user:password@localhost:5432/kc_test_db
TEST_DATABASE_URL=postgresql://kc:test_password@localhost:5432/kc_test_db

# ========================================
# Test Redis Configuration
# ========================================
# Use a separate Redis database index for tests (e.g., /1 instead of /0)
TEST_REDIS_URL=redis://localhost:6379/1

# ========================================
# Test OAuth Configuration
# ========================================
# These can be dummy values for testing
GOOGLE_CLIENT_ID=test-client-id-for-testing
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=test-web-client-id-for-testing

# ========================================
# Notes
# ========================================
# - Never use production credentials in test environment
# - Use a separate test database that can be cleared/reset
# - Set these in CI/CD environment variables for automated testing
