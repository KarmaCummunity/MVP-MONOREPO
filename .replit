modules = ["nodejs-18", "bash", "web"]
[agent]
expertMode = true

[nix]
channel = "stable-25_05"

[[ports]]
localPort = 5000
externalPort = 80

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run web --workspace @kc/mobile -- --port 5000 --host lan"
waitForPort = 5000

[deployment]
deploymentTarget = "static"
build = ["bash", "-c", "cd packages/shared-types && npm run build && cd ../../apps/mobile && npx expo export --platform web"]
publicDir = "apps/mobile/dist"
