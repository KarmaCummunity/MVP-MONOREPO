modules = ["nodejs-18", "bash", "web"]
[agent]
expertMode = true

[nix]
channel = "stable-25_05"

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 8080
externalPort = 8080

[[ports]]
localPort = 8081
externalPort = 8081

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Expo dev server (tunnel)"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "bash -c 'fuser -k 5000/tcp 2>/dev/null; sleep 1; cd apps/mobile && (test -f dist/index.html || npx expo export --platform web) && npx serve -s dist -l tcp://0.0.0.0:5000 --no-clipboard'"
waitForPort = 5000

[[workflows.workflow]]
name = "Expo dev server (tunnel)"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd apps/mobile && npx expo start --tunnel --port 8080"
waitForPort = 8080

[deployment]
deploymentTarget = "static"
build = ["bash", "-c", "cd packages/shared-types && npm run build && cd ../../apps/mobile && npx expo export --platform web"]
publicDir = "apps/mobile/dist"
